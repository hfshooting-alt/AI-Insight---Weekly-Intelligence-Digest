# Required variables
OPENAI_API_KEY=sk-xxx
REPORT_EMAIL_TO=your_report_receiver@example.com

# Optional but recommended (163邮箱)
REPORT_EMAIL_FROM=your_163_account@163.com
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_163_account@163.com
SMTP_PASS=your_163_authorization_code

# Agent behavior
AGENT_MODE=once
REPORT_TIME=10:00
TZ=Asia/Shanghai

# Retrieval tuning
LOOKBACK_HOURS=24
FALLBACK_LOOKBACK_HOURS=168
MAX_PAPERS=12
OPENAI_MODEL=gpt-4o-mini
